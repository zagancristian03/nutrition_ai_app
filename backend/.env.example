# Copy to backend/.env and fill in. Never commit the real file.

# Supabase / Postgres connection string (Project Settings → Database → URI).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# OpenAI — server-side only. The Flutter app never sees this.
# Rotate this key immediately if you ever leak it.
OPENAI_API_KEY=sk-...

# Optional: override the default chat model (gpt-4o-mini is the balanced default).
# OPENAI_MODEL=gpt-4o-mini
