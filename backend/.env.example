# Copy to backend/.env and fill in. Never commit the real file.
# For Docker: docker run --env-file .env  (do not bake .env into the image).

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------
ENVIRONMENT=development
# production  -> Firebase Admin credentials required at startup; CORS must be explicit or empty.

DATABASE_URL=postgresql://user:password@host:5432/postgres

# ------------------------------------------------------------------------------
# Firebase Admin (server only — never put these in the Flutter app)
# ------------------------------------------------------------------------------
# Option A — JSON string (escape newlines or use single-line JSON; typical on Railway/Fly.io):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
#
# Option B — path to service-account file inside the container (mount a secret):
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-adminsdk.json
#
# Optional if you use default application credentials in GCP:
# FIREBASE_PROJECT_ID=your-project-id

FIREBASE_CREDENTIALS_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------------------------
# OpenAI (optional — AI coach fails fast if unset)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# CORS (browser clients only; mobile apps ignore CORS)
# ------------------------------------------------------------------------------
# Comma-separated origins. In production, set your web app origins, e.g.:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
#
# Development: if unset, server uses allow_origins=["*"] with credentials off.
# Production: if unset, allow_origins=[] (strict; mobile/unauthenticated search still works server-side).

CORS_ALLOWED_ORIGINS=
# CORS_ALLOW_CREDENTIALS=true
